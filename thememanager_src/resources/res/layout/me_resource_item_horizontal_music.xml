<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/ring_list_content_padding_top"
    android:paddingBottom="@dimen/ring_list_content_padding_bottom"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/ring_list_content_padding_start"
    android:paddingEnd="@dimen/ring_list_content_padding_end">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/ring_list_playing_height">
            <com.android.thememanager.basemodule.views.ThemeTextView
                android:textSize="17sp"
                android:ellipsize="end"
                android:layout_gravity="center_vertical"
                android:id="@android:id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/ring_list_title_max_width"
                android:singleLine="true"
                app:supportElder="true"
                style="@style/TextAppearance.List.Primary"/>
            <com.airbnb.lottie.LottieAnimationView
                android:theme="@style/Theme.AppCompat"
                android:id="@+id/rc_playing_iv"
                android:visibility="gone"
                style="@style/RingtoneLottieAnimationViewStyle"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:ellipsize="end"
                android:id="@+id/subTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:paddingEnd="@dimen/ring_list_head_subtitle_margin_end"
                style="@style/TextAppearance.List.Secondary"/>
            <ImageView
                android:id="@+id/call_mark"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/rc_ringtone_call"
                android:layout_marginEnd="@dimen/ring_icon_margin_end"/>
            <ImageView
                android:id="@+id/notification_mark"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/rc_ringtone_notification"
                android:layout_marginEnd="@dimen/ring_icon_margin_end"/>
            <ImageView
                android:id="@+id/alarm_mark"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/rc_ringtone_alarm"
                android:layout_marginEnd="@dimen/ring_icon_margin_end"/>
            <ImageView
                android:id="@+id/message_mark"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/rc_rington_message"/>
        </LinearLayout>
    </LinearLayout>
    <Button
        android:textSize="@dimen/ring_apply_text_size"
        android:textColor="@color/settings_ringtone_apply_text_color"
        android:gravity="center"
        android:layout_gravity="end|center_vertical"
        android:id="@+id/operatorBtn"
        android:background="@drawable/rc_apply_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <CheckBox
        android:id="@+id/checkbox"
        android:focusable="false"
        android:visibility="gone"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <ImageView
        android:layout_gravity="end|center_vertical"
        android:id="@+id/stateFlag"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/rc_ringtone_select"
        android:layout_marginEnd="@dimen/ring_list_checked_padding_end"/>
</LinearLayout>
