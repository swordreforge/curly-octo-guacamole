<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:visibility="gone"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/icon_item_preview"
        android:layout_width="@dimen/large_icon_hot_app_item_slide_length"
        android:layout_height="@dimen/large_icon_hot_app_item_slide_length"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/large_icon_hot_app_item_title_text_size"
        android:textColor="@color/large_icon_hot_app_card_title_color"
        android:ellipsize="end"
        android:id="@+id/icon_item_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/large_icon_hot_app_item_title_margin_top"
        android:lines="1"
        android:fontFamily="mipro-regular"
        app:layout_constraintEnd_toEndOf="@+id/icon_item_preview"
        app:layout_constraintStart_toStartOf="@+id/icon_item_preview"
        app:layout_constraintTop_toBottomOf="@+id/icon_item_preview"/>
</androidx.constraintlayout.widget.ConstraintLayout>
