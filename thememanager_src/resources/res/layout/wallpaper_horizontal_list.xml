<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.android.thememanager.view.ThemePreferenceView
        android:id="@+id/preference_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/miuix_preference_item_padding_start"
        android:paddingEnd="@dimen/miuix_preference_item_padding_end"/>
    <miuix.recyclerview.widget.RecyclerView
        android:id="@+id/hRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/wallpaper_setting_group_list_margin_bottom"
        android:nestedScrollingEnabled="false"/>
</LinearLayout>
