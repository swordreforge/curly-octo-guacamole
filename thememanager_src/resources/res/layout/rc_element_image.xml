<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <miuix.smooth.SmoothFrameLayout2
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:radius="@dimen/round_corner_non_recommend_three_img_radius"
        style="@style/SmoothLayoutDefault">
        <com.android.thememanager.basemodule.imageloader.NinePatchImageView
            android:id="@+id/thumbnail"
            android:layout_width="match_parent"
            android:layout_height="@dimen/recommend_font_image_height"
            android:scaleType="centerCrop"/>
        <include layout="@layout/ad_info_container"/>
    </miuix.smooth.SmoothFrameLayout2>
</LinearLayout>
