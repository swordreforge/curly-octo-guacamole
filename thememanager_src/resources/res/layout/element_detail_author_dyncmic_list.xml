<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <include
        android:layout_width="match_parent"
        android:layout_height="@dimen/author_dynamic_content_height"
        android:layout_marginTop="@dimen/author_dynamic_content_margin_top"
        android:layout_marginBottom="@dimen/author_dynamic_content_margin_bottom"
        android:layout_marginStart="@dimen/author_dynamic_content_margin_start"
        layout="@layout/element_author_content"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/item_ll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/author_dynamic_thumbnail_margin_start"
        android:layout_marginEnd="@dimen/author_dynamic_thumbnail_margin_start">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <include
                android:id="@+id/item_0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                layout="@layout/element_detail_author_group_item"/>
            <include
                android:id="@+id/item_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/author_dynamic_thumbnail_margin_start"
                layout="@layout/element_detail_author_group_item"/>
        </LinearLayout>
        <TextView
            android:textSize="@dimen/author_dynamic_title_size"
            android:textColor="@color/common_color"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/element_author_theme_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/author_dynamic_title_margin_top"
            android:layout_marginBottom="@dimen/author_dynamic_title_margin_bottom"
            android:maxWidth="180dp"
            android:singleLine="true"
            android:layout_marginStart="@dimen/author_dynamic_title_margin_start"/>
    </LinearLayout>
    <View
        android:background="@color/author_item_divider"
        android:layout_width="match_parent"
        android:layout_height="0.3dp"
        android:layout_marginStart="@dimen/author_dynamic_title_margin_start"
        android:layout_marginEnd="@dimen/author_dynamic_title_margin_start"/>
</LinearLayout>
