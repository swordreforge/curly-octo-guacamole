<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.android.thememanager.basemodule.imageloader.NinePatchImageView
        android:id="@+id/app_thumbnail"
        android:layout_width="@dimen/rc_slide_ad_card_item_thumbnail_width"
        android:layout_height="@dimen/rc_slide_ad_card_item_thumbnail_height"
        android:scaleType="fitXY"/>
    <include
        android:id="@+id/app_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/rc_slide_ad_card_item_info_margin_top"
        layout="@layout/rc_element_slide_ad_card_item_info"/>
</LinearLayout>
