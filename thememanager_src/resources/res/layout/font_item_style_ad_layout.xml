<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <include
        android:layout_gravity="top|center_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="1px"
        layout="@layout/horizontal_divider"/>
    <FrameLayout
        android:id="@+id/ad_content"
        android:layout_width="match_parent"
        android:layout_height="@dimen/font_recommendation_item_height">
        <TextView
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#ff000000"
            android:layout_gravity="top|center_horizontal"
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginTop="15.33dp"/>
        <TextView
            android:textSize="10sp"
            android:textColor="#e6191919"
            android:ellipsize="end"
            android:layout_gravity="start|bottom"
            android:id="@+id/subTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_marginBottom="7.67dp"
            android:maxWidth="120dp"
            android:maxLines="1"/>
        <ImageView
            android:layout_gravity="end|bottom"
            android:id="@+id/ad_close_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="7dp"
            android:src="@drawable/ad_close_white_btn_selector"
            android:layout_marginEnd="8dp"/>
    </FrameLayout>
    <TextView
        android:textSize="13.33sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:layout_gravity="center"
        android:id="@+id/ad_closed_tip"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ad_closed_tip"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"/>
</FrameLayout>
