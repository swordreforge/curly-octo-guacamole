<?xml version="1.0" encoding="utf-8"?>
<miuix.springback.view.SpringBackLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:scrollOrientation="vertical"
    app:scrollableView="@+id/exchange_container">
    <FrameLayout
        android:id="@+id/exchange_container"
        android:paddingTop="@dimen/me_exchange_content_padding_top"
        android:clickable="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <EditText
            android:id="@+id/edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/resource_exchange_hint"
            android:singleLine="true"
            android:maxLength="30"
            android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
            style="@style/me_ExchangeEdit"/>
        <TextView
            android:textSize="@dimen/me_exchange_alert_size"
            android:textColor="@color/me_exchange_alert_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/me_exchange_alert_margin_top"
            android:maxWidth="@dimen/me_exchange_alert_max_width"
            android:text="@string/exchange_alert"
            android:fontFamily="mipro-regular"
            android:layout_marginStart="@dimen/me_exchange_alert_margin_start"
            android:layout_marginEnd="@dimen/me_exchange_alert_margin_bottom"/>
        <com.android.thememanager.basemodule.views.ThemeButton
            android:layout_gravity="bottom"
            android:id="@+id/exchangeBtn"
            android:layout_marginBottom="@dimen/me_exchange_btn_margin_bottom"
            android:text="@string/resource_exchange"
            app:buttonSupportElder="true"
            style="@style/me_ExchangeBtn"/>
        <com.android.thememanager.basemodule.views.ThemeButton
            android:layout_gravity="bottom"
            android:id="@+id/cancelBtn"
            android:layout_marginBottom="@dimen/me_exchange_btn_cancle_bottom"
            android:text="@android:string/cancel"
            app:buttonSupportElder="true"
            style="@style/CommonButton"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="bottom"
            android:id="@+id/loading"
            android:background="@drawable/loading_view_bg"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <miuix.androidbasewidget.widget.ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/V9LoadingProgressBarVertical"/>
        </LinearLayout>
    </FrameLayout>
</miuix.springback.view.SpringBackLayout>
