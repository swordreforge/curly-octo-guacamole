<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/empty_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/de_detail_empty_comment_content_text_size"
            android:textColor="@color/de_color_30_000000"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/de_detail_empty_comment_content_margin_top"
            android:text="@string/resource_comment_no_comment"/>
        <TextView
            android:textSize="@dimen/de_detail_empty_comment_sub_content_text_size"
            android:textColor="@color/de_color_75_4f5153"
            android:layout_gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/de_detail_empty_comment_sub_content_margin_top"
            android:layout_marginBottom="@dimen/de_detail_empty_comment_sub_content_margin_bottom"
            android:text="@string/de_to_comment"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/top_comment_container"
        android:padding="@dimen/de_detail_top_comment_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/de_detail_top_comment_text_size"
                android:textColor="@color/de_color_70_000000"
                android:id="@+id/comment_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/de_detail_top_comment_text_size"
                android:textColor="@color/de_color_40_000000"
                android:id="@+id/comment_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/de_detail_top_comment_time_margin_start"/>
        </LinearLayout>
        <com.android.thememanager.detail.theme.view.widget.DetailCommentStar
            android:id="@+id/comment_star"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/de_detail_top_comment_star_margin_top"/>
        <TextView
            android:textSize="@dimen/de_detail_top_comment_text_size"
            android:textColor="@color/de_color_45_000000"
            android:ellipsize="end"
            android:id="@+id/comment_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/de_detail_top_comment_content_margin_top"
            android:layout_marginBottom="@dimen/de_detail_top_comment_content_margin_bottom"
            android:maxLines="2"
            android:textDirection="locale"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/comment_more_ll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/de_detail_top_comment_more_text_size"
                android:textColor="@color/de_color_60_000000"
                android:id="@+id/comment_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <ImageView
                android:paddingTop="1dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/de_more_comment_arrow"
                android:paddingStart="2dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
