<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/home_page_hybrid_six_grid_card_margin_top"
    android:layout_marginBottom="@dimen/home_page_hybrid_six_grid_card_margin_bottom">
    <RelativeLayout
        android:id="@+id/head_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/home_page_hybrid_six_grid_card_header_padding_horizontal">
        <com.android.thememanager.basemodule.imageloader.NinePatchImageView
            android:id="@+id/title_logo"
            android:layout_width="@dimen/hot_list_header_title_logo_width"
            android:layout_height="@dimen/hot_list_header_title_logo_height"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="@dimen/home_page_hybrid_six_grid_card_header_title_text_size"
            android:textColor="@color/home_page_hybrid_recommend_card_title_color"
            android:ellipsize="end"
            android:id="@+id/tv_title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif-regular"
            android:textDirection="locale"
            android:layout_toStartOf="@+id/tv_guide"
            android:layout_alignParentStart="true"
            android:paddingVertical="@dimen/home_page_hybrid_six_grid_card_header_title_padding_vertical"
            android:textFontWeight="500"/>
        <TextView
            android:textSize="@dimen/home_page_hybrid_six_grid_card_header_guide_text_size"
            android:textColor="@color/text_color_light_black_40_dark_white_40"
            android:ellipsize="end"
            android:id="@+id/tv_guide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/home_page_hybrid_recommend_card_header_guide_max_width"
            android:maxLines="1"
            android:includeFontPadding="false"
            android:drawablePadding="@dimen/home_page_hybrid_six_grid_card_header_guide_drawable_padding"
            android:layout_centerVertical="true"
            android:drawableEnd="@drawable/ic_hybrid_six_grid_card_arrow"
            android:fontFamily="sans-serif-regular"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <GridLayout
        android:id="@+id/hybrid_recommend_grid_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/hybrid_recommend_grid_container_margin_top"
        android:columnCount="3"/>
</LinearLayout>
