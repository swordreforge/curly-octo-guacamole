<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <miuix.smooth.SmoothFrameLayout2
        android:id="@+id/img_fl"
        android:background="@drawable/personalize_bottom_card_black_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:foreground="@drawable/personalize_card_foreground"
        android:radius="@dimen/pad_round_corner_default"
        app:layout_constraintDimensionRatio="@string/personalized_bottom_card_image_bias"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/preview_img"
            android:padding="@dimen/personalize_border_width"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleType="centerInside"/>
    </miuix.smooth.SmoothFrameLayout2>
    <TextView
        android:textSize="@dimen/personalize_bottom_card_title_text_size"
        android:textStyle="bold"
        android:textColor="@color/personalize_bottom_card_title_color"
        android:id="@+id/title_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/personalize_bottom_card_title_margin_top"
        android:text="@string/personalize_notify_style_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/img_fl"/>
</androidx.constraintlayout.widget.ConstraintLayout>
