<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/nav_view_bottom_container">
    <LinearLayout
        android:layout_gravity="top"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/nav_view_bottom_margin_top">
        <com.android.thememanager.view.NavBottomLottieAnimationView
            android:layout_gravity="center_horizontal"
            android:id="@+id/icon"
            android:visibility="gone"
            android:layout_width="@dimen/elder_nav_view_bottom_width"
            android:layout_height="@dimen/elder_nav_view_bottom_height"/>
        <TextView
            android:textSize="@dimen/nav_view_title_text_size"
            android:textColor="@color/nav_title_text_selector"
            android:gravity="top|center_horizontal"
            android:layout_gravity="center_horizontal"
            android:id="@+id/title"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <ImageView
        android:layout_gravity="top|center_horizontal"
        android:id="@+id/new_message"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/nav_view_bottom_margin_top"
        android:src="@drawable/theme_new_message"
        android:scaleType="center"
        android:layout_marginStart="15dp"/>
</FrameLayout>
