<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/itemview_horizontal_padding_from_screen"
    android:paddingEnd="@dimen/itemview_horizontal_padding_from_screen">
    <RelativeLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="13.7dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="65dp">
            <TextView
                android:id="@+id/name"
                style="@style/RingtoneTitle"/>
            <LinearLayout
                android:gravity="start|center_vertical"
                android:orientation="horizontal"
                android:id="@+id/tag_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp">
                <TextView
                    android:textSize="@dimen/recommend_ring_tag_text_size"
                    android:textColor="@color/ringtone_tag_color6"
                    android:background="@drawable/resource_ringtone_tag_bg6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ad_tag_text_1"
                    android:fontFamily="mipro-demibold"/>
                <TextView
                    android:textSize="@dimen/recommend_ring_tag_text_size"
                    android:textColor="@color/ringtone_tag_color2"
                    android:background="@drawable/resource_ringtone_tag_bg2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ad_tag_text_2"
                    android:fontFamily="mipro-demibold"
                    android:layout_marginStart="5dp"/>
                <ImageView
                    android:id="@+id/ad_close_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/recommend_ad_close"
                    android:layout_marginStart="5dp"/>
            </LinearLayout>
            <com.android.thememanager.basemodule.views.AdSubTextView
                android:textSize="@dimen/recommend_ring_ad_text_size"
                android:textColor="@color/ad_download_btn_border_color"
                android:id="@+id/ad_sub_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="11.27dp"
                android:singleLine="false"
                android:lineSpacingExtra="@dimen/progress_margin_bottom"/>
        </LinearLayout>
        <ImageView
            android:id="@+id/download"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ad_download"
            android:scaleType="center"
            android:minWidth="50dp"
            android:minHeight="50dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</FrameLayout>
