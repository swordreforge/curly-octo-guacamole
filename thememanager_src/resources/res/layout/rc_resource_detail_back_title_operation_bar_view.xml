<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <Button
        android:id="@+id/back_btn"
        android:background="@drawable/recommend_action_bar_back_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/accessibiliy_description_content_back"/>
    <TextView
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_weight="1"
        style="@style/TextAppearance.WindowTitle"/>
    <ImageView
        android:id="@+id/operation_btn"
        android:padding="3dp"
        android:layout_width="@dimen/iv_search_width"
        android:layout_height="@dimen/iv_search_width"
        android:src="@drawable/action_search"
        android:contentDescription="@string/accessibiliy_description_content_search"
        android:layout_marginEnd="9dp"/>
</LinearLayout>
