<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/clock_container_style1"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <Space
        android:id="@+id/time_space_style1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="@dimen/miui_magazine_c_clock_style1_time_margin_bottom"
        app:layout_constraintBottom_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <Space
        android:id="@+id/time_end_space_style1"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/miui_magazine_c_clock_style1_week_notsupport_margin_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.miui.clock.utils.BaseLineSpaceView
        android:id="@+id/week_space_style1"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/miui_magazine_c_clock_style1_week_margin_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.miui.clock.utils.BaseLineSpaceView
        android:id="@+id/date_space_style1"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/miui_magazine_c_clock_style1_date_margin_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/time_container_style1"
        android:layout_width="@dimen/miui_magazine_c_clock_style1_width"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/time_space_style1">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layoutDirection="ltr">
            <com.miui.clock.MiuiTextGlassView
                android:textSize="@dimen/miui_magazine_c_clock_style1_text_size"
                android:id="@+id/current_time_hour_style1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:importantForAccessibility="no"
                android:fontFamily="miclock-neue-matic-compressed-black"
                android:textDirection="locale"
                android:elegantTextHeight="false"/>
            <com.miui.clock.MiuiTextGlassView
                android:textSize="@dimen/miui_magazine_c_clock_style1_text_size"
                android:id="@+id/current_time_minute_style1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:importantForAccessibility="no"
                android:fontFamily="miclock-neue-matic-compressed-black"
                android:textDirection="locale"
                android:elegantTextHeight="false"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/miui_magazine_c_clock_style1_text_size"
        android:id="@+id/current_week_style1"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lines="1"
        android:fontFamily="miclock-neue-matic-compressed-black"
        android:textDirection="locale"
        android:elegantTextHeight="false"
        app:layout_constraintBaseline_toBaselineOf="@+id/week_space_style1"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:textSize="@dimen/miui_magazine_c_clock_style1_text_size"
        android:id="@+id/current_date_style1"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lines="1"
        android:fontFamily="miclock-neue-matic-compressed-black"
        android:textDirection="locale"
        android:elegantTextHeight="false"
        app:layout_constraintBaseline_toBaselineOf="@+id/date_space_style1"
        app:layout_constraintStart_toStartOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
