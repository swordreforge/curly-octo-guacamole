<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/sub_comment_bar_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <EditText
        android:textSize="@dimen/de_sub_comment_bar_edit_text_size"
        android:gravity="center_vertical"
        android:layout_gravity="start|center_vertical"
        android:id="@+id/sub_comment_edit"
        android:background="@drawable/sub_comment_bar_edittext_bg"
        android:layout_width="match_parent"
        android:layout_height="@dimen/de_sub_comment_bar_edit_height"
        android:layout_marginTop="@dimen/de_sub_comment_bar_margin"
        android:layout_marginBottom="@dimen/de_sub_comment_bar_margin"
        android:layout_marginStart="@dimen/de_sub_comment_bar_margin"
        android:layout_marginEnd="@dimen/de_sub_comment_bar_edit_margin"/>
    <FrameLayout
        android:layout_gravity="end|center_vertical"
        android:id="@+id/sub_comment_submit_fl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/de_sub_comment_bar_submit_margin">
        <ImageView
            android:id="@+id/sub_comment_submit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/icon_sub_comment_submit"/>
    </FrameLayout>
</FrameLayout>
