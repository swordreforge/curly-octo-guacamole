<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="bottom"
    android:layout_width="match_parent"
    android:layout_height="220dp">
    <View
        android:id="@+id/offline_divider"
        android:background="@color/setting_wallpaper_divider"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginTop="20dp"/>
    <LinearLayout
        android:gravity="center_horizontal"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:id="@+id/offline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/wifi_img"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/common_margin_l"
            android:src="@drawable/wallpaper_setting_offline_icon"/>
        <TextView
            android:textSize="@dimen/wallpaper_setting_online_wallpaper_text_size"
            android:textColor="@color/common_black"
            android:id="@+id/offline_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/wallpaper_setting_online_wallpaper_text_margin_bottom"
            android:text="@string/wallpaper_online"/>
        <TextView
            android:textSize="@dimen/resource_list_title_size"
            android:textColor="@color/wallpaper_settings_cover_item_count_color"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/offline_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/wallpaper_online_tip"/>
    </LinearLayout>
</FrameLayout>
