<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/search_view_layout"
    android:background="@drawable/search_normal"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="7.7dp"
        android:layoutDirection="ltr"
        android:layout_marginStart="@dimen/itemview_horizontal_padding_from_screen"
        android:layout_marginEnd="@dimen/itemview_horizontal_padding_from_screen">
        <com.android.thememanager.basemodule.imageloader.NinePatchImageView
            android:id="@+id/avatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/icon_default_avatar"
            android:layout_marginEnd="12.67dp"/>
        <com.android.thememanager.basemodule.views.SearchTextSwitcher
            android:id="@+id/switcher"
            android:background="@drawable/search_bg"
            android:layout_width="match_parent"
            android:layout_height="35.33dp"/>
    </LinearLayout>
    <ImageView
        android:layout_gravity="bottom|right"
        android:id="@+id/xiaoai"
        android:layout_width="59.2dp"
        android:layout_height="35.33dp"
        android:layout_marginBottom="7.7dp"
        android:src="@drawable/btn_search_xiaoai"
        android:paddingStart="@dimen/itemview_horizontal_padding_from_screen"
        android:paddingEnd="@dimen/itemview_horizontal_padding_from_screen"/>
</FrameLayout>
