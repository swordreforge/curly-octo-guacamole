<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <miuix.springback.view.SpringBackLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scrollOrientation="vertical"
        app:scrollableView="@+id/component_scroll_view">
        <androidx.core.widget.NestedScrollView
            android:id="@+id/component_scroll_view"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <FrameLayout
                android:paddingBottom="@dimen/component_list_padding_bottom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <fragment
                    android:name="com.android.thememanager.activity.ComponentFragment"
                    android:id="@+id/component_fragment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </FrameLayout>
        </androidx.core.widget.NestedScrollView>
    </miuix.springback.view.SpringBackLayout>
    <com.android.thememanager.basemodule.views.ThemeButton
        android:layout_gravity="bottom"
        android:id="@+id/back_up_component"
        android:layout_marginBottom="@dimen/component_backup_padding_bottom"
        android:text="@string/component_backup_preference_title"
        app:buttonSupportElder="true"
        style="@style/CommonButton"/>
</FrameLayout>
