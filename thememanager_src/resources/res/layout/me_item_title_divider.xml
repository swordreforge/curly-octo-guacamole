<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:focusable="false"
    android:clickable="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/group_divider"
        android:paddingTop="@dimen/me_local_item_padding"
        android:paddingBottom="@dimen/me_local_item_padding"
        android:layout_width="match_parent"
        android:layout_height="@dimen/me_divider_content_height">
        <View
            android:layout_gravity="center"
            android:background="@color/me_divider_color"
            android:layout_width="match_parent"
            android:layout_height="@dimen/me_divider_height"/>
    </FrameLayout>
    <RelativeLayout
        android:id="@+id/item_title_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/me_group_title_margin_top"
        android:layout_marginBottom="@dimen/me_group_title_margin_bottom">
        <TextView
            android:textAppearance="@style/Miuix.AppCompat.TextAppearance.List.GroupHeader"
            android:textSize="@dimen/me_group_title_text_size"
            android:textColor="@color/me_item_title_driver_color"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/item_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="sans-serif-regular"
            android:layout_alignParentStart="true"/>
    </RelativeLayout>
</LinearLayout>
