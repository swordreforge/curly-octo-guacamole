<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/startup_skip_touch_width"
    android:layout_height="@dimen/startup_skip_touch_height"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintTop_toTopOf="parent">
    <TextView
        android:textSize="@dimen/common_text_size_m"
        android:textColor="@android:color/white"
        android:id="@+id/tv_splash_skip"
        android:background="@drawable/shape_bg_button_gray"
        android:paddingTop="@dimen/common_margin_ss"
        android:paddingBottom="@dimen/common_margin_ss"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/common_text_size_xl"
        android:text="@string/common_skip"
        android:paddingStart="@dimen/common_margin_m"
        android:paddingEnd="@dimen/common_margin_m"
        android:layout_marginEnd="@dimen/common_text_size_xl"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
