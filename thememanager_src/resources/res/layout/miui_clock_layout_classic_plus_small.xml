<?xml version="1.0" encoding="utf-8"?>
<com.miui.clock.classic.ClassicPlusClockSmallView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.miui.clock.classic.ClassicTextAreaView
        android:textSize="@dimen/classic_text_area_text_size"
        android:textColor="@color/classic_color_white"
        android:id="@+id/text_area"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/classic_text_area_margin_top_has_face"
        android:fontFamily="mipro-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <View
        android:id="@+id/area1"
        android:layout_width="1dp"
        android:layout_height="@dimen/classic_plus_area_time_height"
        android:layout_marginTop="@dimen/classic_time_area_plus_margin_top"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_area"/>
    <com.miui.clock.MiuiTextGlassView
        android:textSize="@dimen/classic_time_area_plus_text_size"
        android:textColor="@color/classic_color_white"
        android:gravity="center_horizontal"
        android:id="@+id/time_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:letterSpacing="-0.02"
        app:layout_constraintBottom_toBottomOf="@+id/area1"
        app:layout_constraintTop_toTopOf="@+id/area1"/>
    <FrameLayout
        android:id="@+id/magazine_info_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/classic_gallery_area_margin_top_single_line"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/area1"/>
</com.miui.clock.classic.ClassicPlusClockSmallView>
