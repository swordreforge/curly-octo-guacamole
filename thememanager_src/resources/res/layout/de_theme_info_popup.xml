<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/de_theme_detail_info_popup_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/de_detail_info_popup_title_margin_top"
        android:paddingStart="@dimen/de_detail_info_popup_padding_start"
        android:paddingEnd="@dimen/de_detail_info_popup_padding_start">
        <TextView
            android:textSize="@dimen/de_detail_info_dialog_title_text_size"
            android:textStyle="bold"
            android:textColor="@color/de_color_90_000000"
            android:layout_gravity="start|center_vertical"
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/de_detail_info_popup_hide_icon_width"/>
        <ImageView
            android:layout_gravity="end|center_vertical"
            android:id="@+id/hide"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_width="@dimen/de_detail_info_popup_hide_icon_width"
            android:layout_height="@dimen/de_detail_info_popup_hide_icon_height"
            android:src="@drawable/de_icon_theme_info_down"
            android:contentDescription="@string/hide_retract_button"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>
    </FrameLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/de_detail_info_popup_padding_start">
        <com.android.thememanager.detail.theme.view.widget.DetailInfoStar
            android:id="@+id/star"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="@dimen/de_detail_subtitle_text_size"
            android:textColor="@color/de_color_100_ffc93e"
            android:id="@+id/score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="7dp"/>
    </LinearLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:paddingTop="@dimen/de_detail_info_popup_padding_top"
            android:paddingBottom="@dimen/de_detail_info_popup_padding_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/de_detail_info_popup_padding_start"
            android:paddingEnd="@dimen/de_detail_info_popup_padding_end">
            <com.android.thememanager.detail.theme.view.widget.DetailExpandableInfo
                android:id="@+id/description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <com.android.thememanager.detail.theme.view.widget.DetailExpandableInfo
                android:id="@+id/changelog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/de_detail_info_popup_changelog_margin_top"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
