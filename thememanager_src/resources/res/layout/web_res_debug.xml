<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="26.7dp"
        android:paddingRight="26.7dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <CheckBox
            android:id="@+id/debug_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <EditText
            android:id="@+id/hostConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/change_host_hint"
            android:inputType="textMultiLine"/>
        <include
            android:id="@+id/tab1"
            layout="@layout/web_res_tab_item"/>
        <include
            android:id="@+id/tab2"
            layout="@layout/web_res_tab_item"/>
        <include
            android:id="@+id/tab3"
            layout="@layout/web_res_tab_item"/>
        <include
            android:id="@+id/tab4"
            layout="@layout/web_res_tab_item"/>
        <Button
            android:id="@+id/apply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/resource_apply"/>
    </LinearLayout>
</ScrollView>
