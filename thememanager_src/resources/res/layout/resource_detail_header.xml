<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingLeft="@dimen/default_horizontal_offset_from_screen"
    android:paddingTop="@dimen/resource_header_top_padding"
    android:paddingRight="@dimen/default_horizontal_offset_from_screen"
    android:paddingBottom="@dimen/resource_header_bottom_padding"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:gravity="center_vertical"
        android:id="@+id/resource_detail_header_title"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Resource.Detail.TextAppearance.Title"/>
    <LinearLayout
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/resource_detail_header_price"
            style="@style/Resource.Detail.TextAppearance.Title.Secondary"/>
        <TextView
            android:id="@+id/resource_detail_header_price_divider"
            style="@style/Resource.Detail.TextAppearance.Title.Divider"/>
        <TextView
            android:id="@+id/resource_detail_header_size"
            style="@style/Resource.Detail.TextAppearance.Title.Secondary"/>
        <TextView
            android:id="@+id/resource_detail_header_size_divider"
            style="@style/Resource.Detail.TextAppearance.Title.Divider"/>
        <TextView
            android:id="@+id/resource_detail_header_designer"
            android:drawablePadding="14dp"
            style="@style/Resource.Detail.TextAppearance.Title.Secondary"/>
    </LinearLayout>
    <RatingBar
        android:id="@+id/resource_detail_header_ratingbar"
        android:paddingTop="@dimen/resource_header_ratingbar_top_padding"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/Resource.Widget.RatingBar.ReadOnly"/>
</LinearLayout>
