<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/swipe_up_guide_bg_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginBottom="235dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true">
        <ImageView
            android:id="@+id/finger_path"
            android:layout_width="180dp"
            android:layout_height="30dp"
            android:src="@drawable/finger_path"
            android:layout_centerVertical="true"
            android:layout_marginEnd="-190dp"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <View
        android:id="@+id/center_base"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginBottom="360dp"
        android:layout_alignParentBottom="true"/>
    <ImageView
        android:id="@+id/finger"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/finger"
        android:layout_alignTop="@+id/center_base"
        android:layout_alignParentEnd="true"/>
    <TextView
        android:textSize="@dimen/de_resource_comment_text_font_size_average_score"
        android:textColor="@color/miuix_appcompat_text_color_primary_dark"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="130dp"
        android:text="@string/swipe_find_more"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
