<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="@dimen/wallpaper_staggered_divider_double"
    android:paddingEnd="@dimen/wallpaper_staggered_divider_double">
    <miuix.smooth.SmoothFrameLayout2
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/SmoothLayoutDefault">
        <com.android.thememanager.basemodule.imageloader.NinePatchImageView
            android:id="@+id/thumbnail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scaleType="centerCrop"/>
        <include layout="@layout/banner_holder_ad_info_container"/>
    </miuix.smooth.SmoothFrameLayout2>
    <include layout="@layout/ad_info_container_sub_bottom_layout"/>
</LinearLayout>
