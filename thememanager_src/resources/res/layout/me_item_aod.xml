<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <miuix.smooth.SmoothFrameLayout2
        android:id="@+id/image_fl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/SmoothLayoutDefault">
        <com.android.thememanager.basemodule.views.ForegroundImageView
            android:id="@+id/image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="@drawable/aod_item_foreground_frame"
            app:foreground="@drawable/aod_item_foreground_frame"/>
        <TextView
            android:layout_gravity="bottom|center_horizontal"
            android:id="@+id/incompatible"
            android:background="@null"
            android:text="@string/current_version_incompatible"
            style="@style/me_IncompatibleTextView"/>
    </miuix.smooth.SmoothFrameLayout2>
    <TextView
        android:textSize="@dimen/stagger_item_title_size"
        android:textColor="@color/stagger_title_color"
        android:ellipsize="end"
        android:id="@android:id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/stagger_bottom_view_padding_top"
        android:maxLines="1"
        android:layout_marginStart="@dimen/author_work_item_title_horizontal_offset"
        android:layout_marginEnd="@dimen/author_work_item_title_horizontal_offset"
        app:layout_constrainedWidth="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/image_fl"/>
    <TextView
        android:textSize="@dimen/stagger_item_sub_title_size"
        android:textColor="@color/stagger_subtitle_color"
        android:ellipsize="end"
        android:id="@+id/price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/stagger_item_sub_margin_top"
        android:maxLines="1"
        app:layout_constraintStart_toStartOf="@android:id/title"
        app:layout_constraintTop_toBottomOf="@android:id/title"/>
    <TextView
        android:textStyle="bold"
        android:textColor="@color/setting_find_more_text"
        android:id="@+id/current_using"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="1dp"
        android:fontFamily="mipro-regular"
        android:paddingStart="0dp"
        android:layout_marginStart="@dimen/author_work_item_title_horizontal_offset"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@android:id/title"
        style="@style/ResourceBrowser.ResourceDescription.SubDescription"/>
    <CheckBox
        android:id="@+id/checkbox"
        android:focusable="false"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/checkbox_margin"
        android:layout_marginEnd="@dimen/checkbox_margin"
        app:layout_constraintBottom_toBottomOf="@+id/image_fl"
        app:layout_constraintEnd_toEndOf="@+id/image_fl"/>
</androidx.constraintlayout.widget.ConstraintLayout>
