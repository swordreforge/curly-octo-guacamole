<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingBottom="@dimen/local_aod_item_padding_bottom"
    style="@style/ResourceBrowser.ListItem">
    <miuix.smooth.SmoothFrameLayout2
        android:id="@+id/thumbnail_cv"
        android:background="@android:color/transparent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/SmoothLayoutDefault">
        <com.android.thememanager.basemodule.views.ForegroundImageView
            android:id="@+id/thumbnail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="@drawable/aod_item_foreground_frame"
            app:foreground="@drawable/aod_item_foreground_frame"/>
        <include layout="@layout/resource_flag"/>
    </miuix.smooth.SmoothFrameLayout2>
    <TextView
        android:id="@android:id/title"
        android:layout_marginStart="@dimen/author_work_item_title_horizontal_offset"
        android:layout_marginEnd="@dimen/author_work_item_title_horizontal_offset"
        style="@style/ResourceBrowser.ResourceDescription.Vertical"/>
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/author_work_item_title_horizontal_offset"
        android:paddingEnd="@dimen/author_work_item_title_horizontal_offset">
        <TextView
            android:textStyle="bold"
            android:textColor="@color/setting_find_more_text"
            android:id="@+id/current_using"
            android:visibility="gone"
            android:layout_marginTop="1dp"
            android:text="@string/current_using"
            android:paddingStart="0dp"
            style="@style/ResourceBrowser.ResourceDescription.SubDescription"/>
        <include layout="@layout/resource_item_price_view"/>
    </FrameLayout>
</LinearLayout>
