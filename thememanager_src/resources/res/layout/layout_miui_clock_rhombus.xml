<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="ltr">
    <View
        android:id="@+id/colon1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@+id/colon2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <FrameLayout
        android:id="@+id/hour_container"
        android:layout_width="match_parent"
        android:layout_height="@dimen/miui_rhombus_clock_inner_height"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <com.miui.clock.MiuiClockNumberView
            android:layout_gravity="end"
            android:id="@+id/hour1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <com.miui.clock.MiuiClockNumberView
            android:layout_gravity="start"
            android:id="@+id/hour2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/minute_container"
        android:layout_width="match_parent"
        android:layout_height="@dimen/miui_rhombus_clock_inner_height"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <com.miui.clock.MiuiClockNumberView
            android:layout_gravity="end"
            android:id="@+id/minute1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <com.miui.clock.MiuiClockNumberView
            android:layout_gravity="start"
            android:id="@+id/minute2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>
    <View
        android:id="@+id/colon2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/colon1"/>
    <ImageView
        android:id="@+id/colon_view"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
