<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_flag"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_gravity="bottom|left"
        android:orientation="horizontal"
        android:id="@+id/wallpaper_bg_container"
        android:background="@drawable/wallpaper_applied_bg"
        android:padding="2dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/wallpaper_applied_bg_margin"
        android:layout_marginStart="@dimen/wallpaper_applied_bg_margin">
        <TextView
            android:id="@+id/top_flag_lockscreen"
            android:text="@string/current_using_lockscreen_wallpaper_text"
            style="@style/me_ResourceCurrentUsingFlag"/>
        <TextView
            android:id="@+id/top_flag_desktop"
            android:text="@string/current_using_desktop_wallpaper_text"
            style="@style/me_ResourceCurrentUsingFlag"/>
    </LinearLayout>
    <ImageView
        android:layout_gravity="end|bottom"
        android:id="@+id/bottom_flag"
        android:padding="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <CheckBox
        android:layout_gravity="end|bottom"
        android:id="@android:id/checkbox"
        android:focusable="false"
        android:visibility="gone"
        android:clickable="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/checkbox_margin"/>
</FrameLayout>
