<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textAppearance="@style/TextAppearance.BlankPage"
        android:gravity="center_horizontal"
        android:paddingBottom="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_net_work_connection"
        android:drawableTop="@drawable/flower"
        android:drawablePadding="@dimen/no_network_tip_drawable_padding"
        android:lineSpacingExtra="4.7dp"/>
    <Button
        android:id="@+id/reload"
        android:text="@string/reload"
        style="@style/Widget.Button.Rect"/>
</LinearLayout>
