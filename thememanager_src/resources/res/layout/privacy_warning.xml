<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:layout_gravity="center"
        android:id="@+id/privacy_warning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/privacy_warning_map"
        android:src="@drawable/privacy_warning_map"
        android:layout_centerHorizontal="true"/>
    <TextView
        android:textSize="@dimen/privacy_warning_title"
        android:textColor="@color/policy_title_color"
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/privacy_warning_map_bottom"
        android:layout_below="@+id/privacy_warning"
        android:layout_marginHorizontal="@dimen/privacy_revoke_agree_btn_margin_start"
        style="@style/policyContent_style"/>
    <LinearLayout
        android:layout_gravity="center"
        android:id="@+id/privacy_warning_content_scroll"
        android:background="@drawable/privacy_bg"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_below="@+id/title"
        android:layout_marginHorizontal="@dimen/privacy_revoke_agree_btn_margin_end">
        <miuix.springback.view.SpringBackLayout
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="@dimen/privacy_revoke_agree_btn_margin_start"
            app:scrollableView="@+id/scroll_view">
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_view"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/privacy_warning_content"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/privacy_revoke_agree_marginhorizontal">
                    <TextView
                        android:textSize="@dimen/privacy_revoke_agree_introduce"
                        android:textStyle="bold"
                        android:textColor="@color/policy_warning_prompt"
                        android:layout_gravity="center"
                        android:id="@+id/warning_prompt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/policyContent_style"/>
                    <TextView
                        android:id="@+id/warning_content_1"
                        android:layout_marginTop="@dimen/privacy_revoke_agree_warning_content1_to_top"
                        android:layout_marginHorizontal="@dimen/privacy_warning_content_marginhorizontal"
                        style="@style/policyLogoffWarningContent_style"/>
                    <TextView
                        android:id="@+id/warning_content_2"
                        android:layout_marginTop="@dimen/privacy_revoke_agree_warning_content"
                        android:layout_marginHorizontal="@dimen/privacy_revoke_agree_btn_radius"
                        style="@style/policyLogoffWarningContent_style"/>
                    <TextView
                        android:id="@+id/warning_content_3"
                        android:layout_marginTop="@dimen/privacy_revoke_agree_warning_content"
                        android:layout_marginHorizontal="@dimen/privacy_warning_content_marginhorizontal"
                        style="@style/policyLogoffWarningContent_style"/>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </miuix.springback.view.SpringBackLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/check_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/privacy_checkbox_to_bottom"
        android:layout_above="@+id/give_up_retraction"
        android:layout_marginHorizontal="@dimen/privacy_checkbox_marginhorizontal">
        <CheckBox
            android:id="@+id/have_read"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <TextView
            android:textSize="@dimen/privacy_warning_state"
            android:layout_gravity="center_vertical"
            android:id="@+id/have_read_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="@dimen/privacy_checkbox_text_linespacingextra"
            android:layout_marginStart="5.7dp"/>
    </LinearLayout>
    <Button
        android:textColor="@color/privacy_warning_title_color"
        android:id="@+id/give_up_retraction"
        android:background="@drawable/action_privacy_logoff"
        android:layout_width="match_parent"
        android:layout_height="@dimen/privacy_revoke_fragment_know_btn_height"
        android:layout_marginBottom="@dimen/privacy_context_margin_bottom"
        android:layout_above="@+id/retraction_and_exit"
        android:layout_marginHorizontal="@dimen/privacy_revoke_fragment_know_btn_margin_horizontal"
        style="@style/Widget.Button.Primary"/>
    <Button
        android:textColor="@color/privacy_warning_title_color"
        android:layout_gravity="bottom"
        android:id="@+id/retraction_and_exit"
        android:background="@drawable/action_privacy_logoff"
        android:layout_width="match_parent"
        android:layout_height="@dimen/privacy_revoke_fragment_know_btn_height"
        android:layout_marginBottom="@dimen/privacy_revoke_fragment_know_btn_margin_bottom"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="@dimen/privacy_revoke_fragment_know_btn_margin_horizontal"
        style="@style/Widget.Button.Primary"/>
</LinearLayout>
