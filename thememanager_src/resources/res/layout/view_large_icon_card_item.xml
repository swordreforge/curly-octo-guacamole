<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <miuix.smooth.SmoothFrameLayout2
        android:id="@+id/image_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/largeIconItemCardStroke_style">
        <ImageView
            android:id="@+id/preview"
            android:layout_width="@dimen/large_icon_product_preview_slide_length"
            android:layout_height="@dimen/large_icon_product_preview_slide_length"/>
    </miuix.smooth.SmoothFrameLayout2>
    <TextView
        android:textSize="@dimen/large_icon_product_title_text_size"
        android:textStyle="bold"
        android:textColor="@color/large_icon_product_item_title"
        android:ellipsize="end"
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/large_icon_product_title_margin_top"
        android:lines="1"
        android:fontFamily="mipro-medium"
        android:layout_marginStart="@dimen/large_icon_product_title_margin_start"
        app:layout_constraintStart_toStartOf="@+id/image_container"
        app:layout_constraintTop_toBottomOf="@+id/image_container"/>
    <TextView
        android:textSize="@dimen/large_icon_product_price_text_size"
        android:textColor="@color/large_icon_product_item_sub_title"
        android:id="@+id/price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="mipro-regular"
        app:layout_constraintStart_toStartOf="@+id/title"
        app:layout_constraintTop_toBottomOf="@+id/title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
