<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:paddingBottom="15dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_gravity="center_vertical"
        android:orientation="vertical"
        android:paddingTop="@dimen/large_icon_title_padding_top"
        android:paddingBottom="@dimen/large_icon_title_padding_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="200dp">
        <TextView
            android:textSize="@dimen/wallpaper_setting_item_title_size"
            android:textColor="@color/nav_title_color_selected"
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:lines="1"
            android:fontFamily="mipro-medium"/>
    </LinearLayout>
    <miuix.recyclerview.widget.RecyclerView
        android:id="@+id/hRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
