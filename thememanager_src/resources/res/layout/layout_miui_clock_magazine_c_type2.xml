<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/clock_container_style2"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layoutDirection="ltr">
    <com.miui.clock.utils.BaseLineSpaceView
        android:id="@+id/time_space_style2"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/miui_magazine_c_clock_style2_time_margin_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.miui.clock.MiuiTextGlassView
        android:textSize="@dimen/miui_magazine_c_clock_style2_time_text_size"
        android:gravity="end"
        android:id="@+id/current_time_hour_style2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:fontFamily="miclock-neue-matic-compressed-black"
        android:elegantTextHeight="false"
        app:layout_constraintBaseline_toBaselineOf="@+id/time_space_style2"
        app:layout_constraintEnd_toStartOf="@+id/current_time_minute_style2"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"/>
    <com.miui.clock.MiuiTextGlassView
        android:textSize="@dimen/miui_magazine_c_clock_style2_time_text_size"
        android:id="@+id/current_time_minute_style2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:fontFamily="miclock-neue-matic-compressed-black"
        app:layout_constraintBaseline_toBaselineOf="@+id/time_space_style2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/current_time_hour_style2"/>
    <TextView
        android:textSize="@dimen/miui_magazine_c_clock_style2_date_text_size"
        android:id="@+id/current_date_style2"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/miui_magazine_c_clock_style2_date_margin_top"
        android:fontFamily="mipro-medium"
        android:elegantTextHeight="false"
        android:letterSpacing="0.38"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/time_space_style2"/>
</androidx.constraintlayout.widget.ConstraintLayout>
