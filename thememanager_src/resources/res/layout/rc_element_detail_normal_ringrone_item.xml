<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:player="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/recommend_ringtone_second_container"
    android:paddingStart="@dimen/itemview_horizontal_padding_from_screen"
    android:paddingEnd="@dimen/itemview_horizontal_padding_from_screen">
    <RelativeLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textColor="@color/item_resource_audio_sub_title_color"
            android:id="@+id/count"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginEnd="10dp"
            android:layout_alignParentStart="true"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="13.7dp"
            android:layout_centerVertical="true"
            android:layout_marginEnd="65dp"
            android:layout_toEndOf="@+id/count">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="@dimen/ring_list_playing_height">
                <TextView
                    android:id="@+id/name"
                    style="@style/RingtoneTitle"/>
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/audio_playing"
                    android:visibility="gone"
                    android:layout_centerVertical="true"
                    style="@style/RingtoneLottieAnimationViewStyle"/>
                <ImageView
                    android:id="@+id/audio_loading"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/ringtone_back_tone"
                    style="@style/RingtoneLottieAnimationViewStyle"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/recommend_tag_group_margin_top">
                <ViewStub
                    android:id="@+id/tag_group_stub"
                    android:layout="@layout/rc_card_resource_audio_tag_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="7.46dp"/>
                <TextView
                    android:id="@+id/ringtone_info"
                    style="@style/RingtonePlayAmount"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ringtone_line"/>
                <TextView
                    android:id="@+id/ringtone_time"
                    style="@style/RingtonePlayTime"/>
            </LinearLayout>
        </LinearLayout>
        <Button
            android:textSize="@dimen/ring_tone_set_color_ring_text_size"
            android:textColor="@color/common_white"
            android:id="@+id/ringtone_back_tone"
            android:background="@drawable/color_ring_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/set_calling"
            android:layout_centerVertical="true"
            android:contentDescription="@string/set_calling"
            android:layout_marginEnd="@dimen/ring_tone_set_color_ring_margin_end"
            android:layout_toStartOf="@+id/audio_more"/>
        <ImageView
            android:id="@+id/audio_more"
            android:paddingBottom="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ring_more"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</FrameLayout>
