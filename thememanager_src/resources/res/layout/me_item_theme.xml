<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:paddingBottom="@dimen/me_itemview_triple_vertical_theme_padding_from_bottom"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/thumbnail_fl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.android.thememanager.basemodule.imageloader.NinePatchImageView
            android:id="@+id/thumbnail"
            style="@style/me_ThreeGridItemThumbnailView"/>
        <TextView
            android:id="@+id/incompatible"
            android:text="@string/current_version_incompatible"
            style="@style/me_IncompatibleTextView"/>
    </FrameLayout>
    <CheckBox
        android:id="@+id/checkbox"
        android:layout_alignBottom="@+id/thumbnail_fl"
        style="@style/BatchOperationCheckboxBtn"/>
    <TextView
        android:ellipsize="end"
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:maxWidth="@dimen/three_group_title_max_width"
        android:singleLine="true"
        android:layout_below="@+id/thumbnail_fl"
        android:paddingStart="0dp"
        style="@style/ResourceBrowser.ResourceDescription.Vertical"/>
    <TextView
        android:id="@+id/time"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_below="@+id/title"
        android:layout_alignParentEnd="true"
        style="@style/ResourceBrowser.ResourceDescription.SubDescription"/>
    <com.android.thememanager.basemodule.views.DiscountPriceView
        android:id="@+id/price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/three_group_subtitle_margin_top"
        android:layout_below="@+id/title"
        android:layout_alignStart="@+id/time"
        android:layout_alignParentStart="true"/>
</RelativeLayout>
