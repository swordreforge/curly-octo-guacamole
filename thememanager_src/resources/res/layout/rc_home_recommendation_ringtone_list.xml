<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/container"
    android:background="@drawable/card_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/stagger_image_height">
        <com.android.thememanager.basemodule.imageloader.NinePatchImageView
            android:id="@+id/image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/ringtone_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"/>
    </FrameLayout>
    <LinearLayout
        android:id="@+id/stagger_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/StaggerItemBottomContainer">
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/StaggerItemTitle"/>
        <TextView
            android:id="@+id/numbers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/StaggerItemSubTitle"/>
        <com.android.thememanager.recommend.view.widget.TagUIContainer
            android:orientation="horizontal"
            android:id="@+id/tag_ui_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/tagui_margin_top"
            app:leftAndRightSpace="10dp"/>
    </LinearLayout>
</LinearLayout>
