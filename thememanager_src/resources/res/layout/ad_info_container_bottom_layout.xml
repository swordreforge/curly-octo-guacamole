<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:id="@+id/ad_bottom_layout"
    android:paddingTop="@dimen/ad_info_pure_xout_padding"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    style="@style/Icon_StaggerItemBottomContainer">
    <TextView
        android:id="@+id/ad_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/ad_info_tag_top_offset"
        style="@style/AdBottomTitleStyle"/>
    <include
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/progress_margin_end"
        layout="@layout/ad_bottom_download_button"/>
</LinearLayout>
