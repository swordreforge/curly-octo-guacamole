<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.miui.clock.utils.BaseLineSpaceView
        android:id="@+id/hour_space"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/miui_smart_frame_clock_hour_margin_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.miui.clock.utils.BaseLineSpaceView
        android:id="@+id/minute_space"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/miui_smart_frame_clock_minute_margin_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/miui_smart_frame_clock_time_text_size"
        android:id="@+id/current_time_hour1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:fontFamily="miclock-gulfs-display-extra-expanded-italic"
        android:layout_marginStart="@dimen/miui_smart_frame_clock_time_margin_start"
        android:elegantTextHeight="false"
        app:layout_constraintBaseline_toBaselineOf="@+id/hour_space"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:textSize="@dimen/miui_smart_frame_clock_time_text_size"
        android:id="@+id/current_time_hour2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:fontFamily="miclock-gulfs-display-extra-expanded-italic"
        android:layout_marginStart="@dimen/miui_smart_frame_clock_time_letter_space"
        android:elegantTextHeight="false"
        app:layout_constraintBaseline_toBaselineOf="@+id/hour_space"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:textSize="@dimen/miui_smart_frame_clock_time_text_size"
        android:id="@+id/current_time_minute1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:importantForAccessibility="no"
        android:fontFamily="miclock-gulfs-display-extra-expanded-italic"
        android:layout_marginStart="@dimen/miui_smart_frame_clock_time_margin_start"
        android:elegantTextHeight="false"
        app:layout_constraintBaseline_toBaselineOf="@+id/minute_space"
        app:layout_constraintStart_toStartOf="parent"/>
    <TextView
        android:textSize="@dimen/miui_smart_frame_clock_time_text_size"
        android:id="@+id/current_time_minute2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:importantForAccessibility="no"
        android:fontFamily="miclock-gulfs-display-extra-expanded-italic"
        android:layout_marginStart="@dimen/miui_smart_frame_clock_time_letter_space"
        android:elegantTextHeight="false"
        app:layout_constraintBaseline_toBaselineOf="@+id/minute_space"
        app:layout_constraintStart_toStartOf="parent"/>
    <View
        android:id="@+id/view_line"
        android:layout_width="match_parent"
        android:layout_height="@dimen/miui_smart_frame_clock_line_height"
        android:layout_marginTop="@dimen/miui_smart_frame_clock_line_margin_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="@dimen/miui_smart_frame_clock_date_text_size"
        android:id="@+id/current_week"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/miui_smart_frame_clock_date_margin_bottom"
        android:fontFamily="mipro-regular"
        android:layout_marginEnd="@dimen/miui_smart_frame_clock_week_margin_end"
        android:elegantTextHeight="false"
        app:layout_constraintBottom_toTopOf="@+id/view_line"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:textSize="@dimen/miui_smart_frame_clock_date_text_size"
        android:id="@+id/current_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/miui_smart_frame_clock_date_margin_bottom"
        android:fontFamily="mipro-regular"
        android:layout_marginEnd="@dimen/miui_smart_frame_clock_date_margin_end"
        android:elegantTextHeight="false"
        app:layout_constraintBottom_toTopOf="@+id/view_line"
        app:layout_constraintEnd_toStartOf="@+id/current_week"/>
</androidx.constraintlayout.widget.ConstraintLayout>
