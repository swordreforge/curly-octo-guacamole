<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="140dp"
    android:paddingStart="@dimen/itemview_horizontal_padding_from_screen"
    android:paddingEnd="@dimen/itemview_horizontal_padding_from_screen">
    <include
        android:layout_width="wrap_content"
        android:layout_height="1px"
        android:layout_alignParentTop="true"
        layout="@layout/rc_horizontal_divider"/>
    <com.android.thememanager.basemodule.imageloader.NinePatchImageView
        android:id="@+id/image"
        android:layout_width="113.3dp"
        android:layout_height="113.3dp"
        android:layout_marginTop="@dimen/itemview_vertical_padding_from_screen"
        android:layout_marginBottom="@dimen/itemview_vertical_padding_from_screen"
        android:layout_alignParentStart="true"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="12.7dp"
        android:layout_marginEnd="18dp"
        android:layout_toEndOf="@+id/image">
        <View
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="3"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/item_resource_audio_single_ring_ranking_list_text_color"
            android:ellipsize="end"
            android:id="@+id/singer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/item_resource_audio_single_ring_ranking_list_text_color"
            android:ellipsize="end"
            android:id="@+id/info1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:singleLine="true"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/item_resource_audio_single_ring_ranking_list_text_color"
            android:ellipsize="end"
            android:id="@+id/info2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:singleLine="true"/>
        <TextView
            android:textSize="12sp"
            android:textColor="@color/item_resource_audio_single_ring_ranking_list_text_color"
            android:ellipsize="end"
            android:id="@+id/info3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:singleLine="true"/>
        <View
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_weight="2"/>
    </LinearLayout>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/audio_more"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/audio_ring_ranking_list_more_selector"
        android:layout_centerVertical="true"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
