<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <miuix.springback.view.SpringBackLayout
        android:id="@+id/sbl"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scrollableView="@+id/recyclerView">
        <miuix.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"/>
    </miuix.springback.view.SpringBackLayout>
    <ViewStub
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/viewStub"
        android:layout="@layout/stub_find_more"
        android:inflatedId="@+id/find_more"
        android:layout_width="match_parent"
        android:layout_height="@dimen/wallpaper_setting_find_more_button_height"
        android:layout_marginHorizontal="@dimen/theme_and_icon_setting_find_more_button_margin_horizontal"/>
</FrameLayout>
