<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/container"
    android:background="@drawable/card_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <miuix.smooth.SmoothFrameLayout2
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/SmoothLayoutDefault">
        <com.google.android.exoplayer2.ui.PlayerView
            android:layout_gravity="center"
            android:id="@+id/video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:controller_layout_id="@layout/rc_ad_video_player_control_view"
            app:player_layout_id="@layout/video_wallpaper_player_view"
            app:repeat_toggle_modes="none"
            app:resize_mode="zoom"
            app:show_timeout="0"
            app:surface_type="texture_view"/>
        <com.android.thememanager.basemodule.imageloader.NinePatchImageView
            android:layout_gravity="center"
            android:id="@+id/image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/ad_pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ad_pause_icon"/>
        <View
            android:id="@+id/touch"
            android:background="@android:color/transparent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <FrameLayout
            android:id="@+id/ad_info_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:id="@+id/ad_close_btn"
                android:text="@string/accessibiliy_description_content_ad"
                style="@style/Vertical_Ad_Text_Style"/>
        </FrameLayout>
    </miuix.smooth.SmoothFrameLayout2>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/ad_message_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/ad_video_message_container_margin_top">
        <TextView
            android:textSize="@dimen/ad_video_title_size"
            android:textColor="@color/ad_video_color"
            android:id="@+id/ad_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="mipro-regular"
            android:layout_marginStart="@dimen/ad_video_message_container_margin_start"/>
        <FrameLayout
            android:id="@+id/ad_download_container"
            android:paddingTop="@dimen/ad_video_downloader_container_padding_top"
            android:paddingBottom="@dimen/ad_video_downloader_container_padding_bottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/ad_video_downloader_container_padding_start"
            android:paddingEnd="@dimen/ad_video_downloader_container_padding_end">
            <Button
                android:gravity="center"
                android:id="@+id/add_download"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ad_info_btn_margin"
                android:text="@string/ad_download_download_now"
                android:layout_centerVertical="true"
                android:layout_marginEnd="@dimen/ad_info_btn_margin"
                android:layout_alignParentEnd="true"
                style="@style/adBottomDownloadBtn"/>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
