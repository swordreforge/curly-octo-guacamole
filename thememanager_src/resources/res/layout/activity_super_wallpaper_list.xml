<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <miuix.springback.view.SpringBackLayout
        android:id="@+id/spring_back"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/super_wallpaper_list_padding_start_end"
        android:layout_marginEnd="@dimen/super_wallpaper_list_padding_start_end"
        app:scrollOrientation="vertical"
        app:scrollableView="@+id/super_wallpaper_list">
        <miuix.recyclerview.widget.RecyclerView
            android:id="@+id/super_wallpaper_list"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fadeScrollbars="true"/>
    </miuix.springback.view.SpringBackLayout>
    <ViewStub
        android:id="@+id/webview_reload_stub"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</FrameLayout>
