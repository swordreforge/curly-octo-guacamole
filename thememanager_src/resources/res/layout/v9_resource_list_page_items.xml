<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <miuix.miuixbasewidget.widget.MessageView
        android:id="@+id/alert_msg"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/long_click_can_hide_resource"
        style="@style/Widget.MessageView.Guide"/>
    <FrameLayout
        android:id="@+id/root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <miuix.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:background="@color/item_color"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <ViewStub
            android:id="@+id/webview_reload_stub"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <include layout="@layout/v9_loading_progress"/>
    </FrameLayout>
</LinearLayout>
