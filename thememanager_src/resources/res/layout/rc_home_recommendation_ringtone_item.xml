<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="@dimen/ringtone_recommendation_item_height"
        android:layout_marginTop="18.67dp">
        <TextView
            android:textSize="14.66sp"
            android:textColor="@android:color/white"
            android:ellipsize="marquee"
            android:layout_gravity="start|top"
            android:id="@+id/title"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:marqueeRepeatLimit="marquee_forever"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"/>
        <TextView
            android:textSize="11sp"
            android:textColor="@android:color/white"
            android:id="@+id/count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginStart="10dp"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="11.33dp"
            android:layout_marginEnd="11.33dp">
            <TextView
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:gravity="center"
                android:id="@+id/audition"
                android:background="@drawable/resource_recommendation_audio_audition_tag_bg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="14dp"
                android:text="@string/audition_ringtone"
                android:layout_weight="1"/>
            <TextView
                android:textSize="11sp"
                android:textColor="@android:color/black"
                android:gravity="center"
                android:id="@+id/apply"
                android:background="@drawable/resource_recommendation_audio_apply_tag_bg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/resource_apply"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
